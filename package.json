{
  "name": "pi-minimal-subagent",
  "version": "1.0.0",
  "description": "Unified subagent tool for Pi — run agents, workflows, goal loops. Live TUI widgets, event bus, durable state.",
  "author": "drvova",
  "type": "module",
  "keywords": [
    "pi",
    "subagent",
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "test": "node --test src/**/*.test.*",
    "typecheck": "tsc --noEmit",
    "bun:compile": "bun build --compile --minify ./src/index.ts --outfile dist/pi-minimal-subagent"
  },
  "license": "MIT",
  "peerDependencies": {
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "files": [
    "README.md",
    "package.json",
    "src"
  ],
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
